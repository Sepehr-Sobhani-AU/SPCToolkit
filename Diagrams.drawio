        </mxCell>
        <mxCell id="TSCh-ubsTvimD4tnIFDC-230" value="Point Cloud Data Loading" style="fillColor=#ffff88;strokeColor=#9E916F;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Times New Roman;fontSize=18;" parent="1" vertex="1">
