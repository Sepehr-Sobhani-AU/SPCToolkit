        </mxCell>
        <mxCell id="TSCh-ubsTvimD4tnIFDC-234" value="Results Export (Optional)" style="fillColor=#ffff88;strokeColor=#9E916F;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Times New Roman;fontSize=18;" parent="1" vertex="1">
          <mxGeometry x="-574" y="20392" width="194" height="49" as="geometry" />
        </mxCell>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Plugin Architecture Class Diagram\n\n&#39; Interfaces\ninterface AnalysisPlugin {\n  +get_name(): str\n  +get_parameters(): Dict[str, Any]\n  +execute(data_node: DataNode, params: Dict[str, Any]): Tuple[Any, str, List]\n}\n\ninterface MenuPlugin {\n  +get_menu_location(): str\n  +get_menu_items(): List[Dict[str, Any]]\n  +handle_action(action_name: str, main_window)\n}\n\n&#39; Core classes\nclass PluginManager {\n  -plugin_dirs: List[str]\n  -analysis_plugins: Dict[str, Type[AnalysisPlugin]]\n  -menu_plugins: List[MenuPlugin]\n  +__init__(plugin_dirs=None)\n  +load_plugins()\n  +get_analysis_plugins(): Dict[str, Type[AnalysisPlugin]]\n  +get_menu_plugins(): List[MenuPlugin]\n}\n\nclass AnalysisManager {\n  -plugin_manager: PluginManager\n  +analysis_completed: pyqtSignal\n  +__init__(plugin_manager: PluginManager)\n  +apply_analysis(data: DataNode, analysis_type: str, params: Dict[str, Any])\n}\n\nclass MainWindow {\n  -plugin_manager: PluginManager\n  -menus: Dict[str, QMenu]\n  +__init__(plugin_manager: PluginManager)\n  +setup_ui()\n  +populate_menus_from_plugins()\n  +open_dialog_box(analysis_type: str)\n}\n\nclass DialogBoxesManager {\n  -plugin_manager: PluginManager\n  +analysis_params: pyqtSignal\n  +__init__(plugin_manager: PluginManager)\n  +open_dialog_box(analysis_type: str)\n}\n\nclass DynamicDialog {\n  -parameter_schema: Dict[str, Any]\n  -param_widgets: Dict[str, QWidget]\n  -params: Dict[str, Any]\n  +__init__(title, parameter_schema, parent=None)\n  +setup_ui()\n  +get_parameters(): Dict[str, Any]\n}\n\nclass DataManager {\n  -analysis_manager: AnalysisManager\n  -file_manager: FileManager\n  -tree_widget: TreeStructureWidget\n  -viewer_widget: PCDViewerWidget\n  -dialog_boxes_manager: DialogBoxesManager\n  +__init__(file_manager, tree_widget, viewer_widget, dialog_boxes_manager, analysis_manager)\n  +apply_analysis(analysis_type: str, params: dict)\n}\n\n&#39; Example plugins\nclass DBSCANPlugin {\n  +get_name(): str\n  +get_parameters(): Dict[str, Any]\n  +execute(data_node: DataNode, params: Dict[str, Any]): Tuple[Any, str, List]\n}\n\nclass KMeansPlugin {\n  +get_name(): str\n  +get_parameters(): Dict[str, Any]\n  +execute(data_node: DataNode, params: Dict[str, Any]): Tuple[Any, str, List]\n}\n\nclass ClusteringMenuPlugin {\n  +get_menu_location(): str\n  +get_menu_items(): List[Dict[str, Any]]\n  +handle_action(action_name: str, main_window)\n}\n\nclass FilteringMenuPlugin {\n  +get_menu_location(): str\n  +get_menu_items(): List[Dict[str, Any]]\n  +handle_action(action_name: str, main_window)\n}\n\n&#39; Relationships\nAnalysisPlugin &lt;|.. DBSCANPlugin\nAnalysisPlugin &lt;|.. KMeansPlugin\nMenuPlugin &lt;|.. ClusteringMenuPlugin\nMenuPlugin &lt;|.. FilteringMenuPlugin\n\nPluginManager o-- \&quot;0..*\&quot; AnalysisPlugin : manages &gt;\nPluginManager o-- \&quot;0..*\&quot; MenuPlugin : manages &gt;\n\nAnalysisManager --&gt; PluginManager : uses &gt;\nMainWindow --&gt; PluginManager : uses &gt;\nDialogBoxesManager --&gt; PluginManager : uses &gt;\n\nMainWindow --&gt; DialogBoxesManager : uses &gt;\nDataManager --&gt; AnalysisManager : uses &gt;\nDataManager --&gt; DialogBoxesManager : uses &gt;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="TSCh-ubsTvimD4tnIFDC-235">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;fontFamily=Tahoma;" parent="1" vertex="1">
            <mxGeometry x="-390" y="21390" width="1907" height="899" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml Plugin Execution Sequence Diagram\n\nactor User\nparticipant MainWindow\nparticipant PluginManager\nparticipant \&quot;MenuPlugin\\nImplementation\&quot; as MenuPlugin\nparticipant DialogBoxesManager\nparticipant DynamicDialog\nparticipant \&quot;AnalysisPlugin\\nImplementation\&quot; as AnalysisPlugin\nparticipant AnalysisManager\nparticipant DataManager\nparticipant \&quot;DataNode\&quot; as DataNode\n\n&#39; Application startup and plugin loading\nUser -&gt; MainWindow : start application\nactivate MainWindow\nMainWindow -&gt; PluginManager : new PluginManager()\nactivate PluginManager\nPluginManager -&gt; PluginManager : load_plugins()\nnote right of PluginManager\n  Scan plugin directories,\n  import modules, and\n  register plugins\nend note\nMainWindow -&gt; MainWindow : populate_menus_from_plugins()\nMainWindow --&gt; User : show UI with plugin menus\ndeactivate PluginManager\n\n&#39; User selects a menu item from a plugin\nUser -&gt; MainWindow : click plugin menu item\nactivate MainWindow\nMainWindow -&gt; MenuPlugin : handle_action(action_name, main_window)\nactivate MenuPlugin\nMenuPlugin -&gt; MainWindow : open_dialog_box(analysis_type)\ndeactivate MenuPlugin\nMainWindow -&gt; DialogBoxesManager : open_dialog_box(analysis_type)\nactivate DialogBoxesManager\n\n&#39; Dialog for parameter input\nDialogBoxesManager -&gt; PluginManager : get_analysis_plugins()\nPluginManager --&gt; DialogBoxesManager : return analysis_plugins\nDialogBoxesManager -&gt; AnalysisPlugin : get_parameters()\nactivate AnalysisPlugin\nAnalysisPlugin --&gt; DialogBoxesManager : return parameter_schema\ndeactivate AnalysisPlugin\nDialogBoxesManager -&gt; DynamicDialog : new DynamicDialog(parameter_schema)\nactivate DynamicDialog\nDynamicDialog --&gt; User : show parameter dialog\nUser -&gt; DynamicDialog : input parameters and click OK\nDynamicDialog -&gt; DynamicDialog : get_parameters()\nDynamicDialog --&gt; DialogBoxesManager : return params\ndeactivate DynamicDialog\nDialogBoxesManager -&gt;&gt; DataManager : emit analysis_params(analysis_type, params)\ndeactivate DialogBoxesManager\n\n&#39; Analysis execution\nactivate DataManager\nDataManager -&gt; DataManager : get selected data_node\nDataManager -&gt; AnalysisManager : apply_analysis(data_node, analysis_type, params)\nactivate AnalysisManager\nAnalysisManager -&gt; PluginManager : get_analysis_plugins()\nPluginManager --&gt; AnalysisManager : return analysis_plugins\nAnalysisManager -&gt; AnalysisPlugin : new plugin_instance()\nactivate AnalysisPlugin\nAnalysisManager -&gt; AnalysisPlugin : execute(data_node, params)\nAnalysisPlugin -&gt; DataNode : access data\nDataNode --&gt; AnalysisPlugin : return data\nAnalysisPlugin --&gt; AnalysisManager : return result, result_type, dependencies\ndeactivate AnalysisPlugin\nAnalysisManager -&gt;&gt; DataManager : emit analysis_completed signal\ndeactivate AnalysisManager\n\n&#39; Result handling\nDataManager -&gt; DataManager : create new DataNode with result\nDataManager -&gt; \&quot;TreeStructureWidget\&quot; : add_branch(result_node)\nDataManager -&gt; \&quot;PCDViewerWidget\&quot; : update view\nDataManager --&gt; User : show analysis results\ndeactivate DataManager\ndeactivate MainWindow\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="TSCh-ubsTvimD4tnIFDC-236">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;fontSize=19;" parent="1" vertex="1">
            <mxGeometry x="-611.55" y="22460" width="2306" height="1227" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
