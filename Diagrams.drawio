        <mxCell id="FdGPhG3aANbtVTZCnWhw-29" value="TreeStructureWidget" style="shape=table;startSize=25;container=1;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=1;fontStyle=1;align=center;resizeLast=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Tahoma;fontSize=20;" parent="1" vertex="1">
