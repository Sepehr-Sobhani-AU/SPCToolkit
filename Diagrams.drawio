<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/133.0.0.0 Safari/537.36" version="26.0.16">
  <diagram name="Page-1" id="jd0CBrk4xv-4FXGMu2V4">
    <mxGraphModel dx="3794" dy="-264" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1654" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="7ffbXIrrkXdQScSVe2Ly-69" value="" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Tahoma;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=20;fontColor=default;labelBackgroundColor=default;fillColor=none;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" parent="1" vertex="1">
          <mxGeometry x="-30" y="14220" width="310" height="70" as="geometry" />
        </mxCell>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nactor User\ncontrol TreeStructureWidget\ncontrol DataManager #orange\nentity DataNodes\nentity PCDViewerWidget\nentity AnalysisManager\n\n== Adding a Branch ==\nUser -&gt; DataManager: Add branch (Load point cloud)\nDataManager -&gt; DataNodes: Add data node (type: raw)\nDataManager -&gt; TreeStructureWidget: Add branch to tree\nDataManager -&gt; PCDViewerWidget: Render data node\n\n== Selecting Branches ==\nUser -&gt; TreeStructureWidget: Select branches\nTreeStructureWidget -&gt; DataManager: Notify selected branches\n\n== Deleting Selected Branches ==\nUser -&gt; DataManager: Delete selected branches\nDataManager -&gt; TreeStructureWidget: Remove branches from tree\n\nloop For each branch to delete\n    TreeStructureWidget -&gt; DataManager: Notify deletion of branch\n    DataManager -&gt; DataNodes: Check for dependencies\n    alt Dependencies Exist\n        DataManager -&gt; TreeStructureWidget: Raise error (Dependency exists)\n    else No Dependencies\n        DataManager -&gt; DataNodes: Remove branch and its child branches from dictionary\n        alt Branch has children\n            DataManager -&gt; DataNodes: Recursively remove all child branches\n        end\n        DataManager -&gt; PCDViewerWidget: Update rendering\n    end\nend\n\n== Moving Selected Branches ==\nUser -&gt; TreeStructureWidget: Move selected branches\nTreeStructureWidget -&gt; TreeStructureWidget: Update parent of branch\nTreeStructureWidget -&gt; DataManager: Notify updated branch hierarchy\nDataManager -&gt; DataNodes: Validate parent dependency\nalt Dependencies Exist\n    DataManager -&gt; TreeStructureWidget: Raise error (Invalid move)\nelse No Dependencies\n    DataManager -&gt; DataNodes: Update parent-child relationship\n    DataManager -&gt; PCDViewerWidget: Update rendering if necessary\nend\n\n== Toggling Visibility ==\nUser -&gt; TreeStructureWidget: Toggle visibility of a branch\nTreeStructureWidget -&gt; DataManager: Notify visibility changes\nDataManager -&gt; DataNodes: Check if branch is derived or raw\n\nalt Derived Branch\n    DataNodes -&gt; DataManager: Retrieve parent data dependency\n    DataManager -&gt; PCDViewerWidget: Render derived data using parent data\nelse Raw Branch\n    DataManager -&gt; PCDViewerWidget: Update visibility rendering\nend\n\n== Applying a Task ==\nUser -&gt; DataManager: Apply a task/analysis on selected branches\nDataManager -&gt; DataNodes: Validate dependencies\nDataManager -&gt; AnalysisManager: Perform analysis (on selected data node(s))\nAnalysisManager -&gt; DataManager: Return analysis result\nDataManager -&gt; DataNodes: Add derived data node (type: derived, depends_on: parent UUID)\nDataManager -&gt; TreeStructureWidget: Add new branch for derived data\nDataManager -&gt; PCDViewerWidget: Render derived data\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="VsBj7MzGJR5kxG5B942g-132">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;fontSize=20;fontFamily=Tahoma;" parent="1" vertex="1">
            <mxGeometry x="-88.55000000000001" y="1840" width="1213" height="1583" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\npackage \&quot;PCD Toolkit Application\&quot; {\n    \n    actor User\n    \n    component \&quot;TreeStructureWidget\&quot; {\n        note right of TreeStructureWidget\n        - Displays and manages branches\n        - Handles user interactions: add, move, delete, toggle visibility\n        end note\n    }\n    \n    component \&quot;DataManager\&quot; #orange {\n        note right of DataManager\n        - Coordinates data operations\n        - Manages interactions between components\n        - Ensures dependency validation\n        end note\n    }\n    \n    package \&quot;Data Management\&quot; {\n        component \&quot;DataNodes\&quot; {\n            note bottom of DataNodes\n            - Unified dictionary storing raw and derived data nodes\n            - Manages parent-child relationships\n            end note\n        }\n    }\n    \n    component \&quot;PCDViewerWidget\&quot; {\n        note right of PCDViewerWidget\n        - Renders data nodes\n        - Updates visibility based on user input\n        end note\n    }\n    \n    component \&quot;AnalysisManager\&quot; {\n        note right of AnalysisManager\n        - Performs analyses on data nodes\n        - Produces derived results\n        end note\n    }\n    \n    package \&quot;Derived Data\&quot; {\n        component \&quot;AnalysisResult\&quot; {\n            note bottom of AnalysisResult\n            - Contains analysis output\n            - Tracks dependency relationships\n            end note\n        }\n    }\n    \n    User --&gt; TreeStructureWidget : User Interactions\n    TreeStructureWidget --&gt; DataManager : Notify actions (add/move/delete/toggle)\n    DataManager --&gt; DataNodes : Manage data nodes\n    DataManager --&gt; AnalysisManager : Request analysis\n    AnalysisManager --&gt; DataNodes : Add derived nodes\n    AnalysisManager --&gt; AnalysisResult : Produce results\n    DataManager --&gt; TreeStructureWidget : Update branches\n    DataManager --&gt; PCDViewerWidget : Render updates\n    PCDViewerWidget --&gt; DataNodes : Fetch data for rendering\n\n}\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="VsBj7MzGJR5kxG5B942g-133">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;fontSize=20;fontFamily=Tahoma;" parent="1" vertex="1">
            <mxGeometry x="24.44999999999999" y="3670" width="954" height="947" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nclass DataManager {\n    - data_nodes : DataNodes\n    - analysis_manager : AnalysisManager\n    - tree_structure_widget : TreeStructureWidget\n    - viewer_widget : PCDViewerWidget\n    --\n    + load_data_node(file_path: str): None\n    + move_branch(uids: list[str], new_parent_uid: str): None\n    + delete_branch(uids: list[str]): None\n    + toggle_visibility(uids: list[str], visibility: bool): None\n    + apply_analysis(uids: list[str], analysis_type: str, params: dict): list[str]\n    - validate_dependencies(uids: list[str]): bool\n}\n\nclass DataNodes {\n    - data_nodes : dict[UUID, DataNode]\n    --\n    + add_data(data: DataNode): UUID\n    + remove_data(uids: list[UUID]): bool\n    + get_data(uid: UUID): DataNode\n    + update_parent(uid: UUID, new_parent_uid: UUID): None\n    + validate_dependency(uids: list[UUID]): bool\n}\n\nclass DataNode {\n    - uuid : UUID\n    - name : str\n    - data : object\n    - parent_uid : UUID\n    - depends_on : UUID\n    - tags : list[str]\n    --\n    + get_metadata(): dict\n    + update_metadata(metadata: dict): None\n}\n\nclass TreeStructureWidget {\n    - branches_dict : dict[UUID, Branch]\n    - visibility_status : dict[UUID, bool]\n    --\n    + add_branch(uuid: str, parent_uuid: str, name: str): None\n    + remove_branch(uids: list[str]): None\n    + move_branch(uids: list[str], new_parent_uuid: str): None\n    + toggle_visibility(uids: list[str]): None\n}\n\nclass Branch {\n    - uuid : UUID\n    - name : str\n    - parent_uuid : UUID\n    --\n}\n\nclass AnalysisManager {\n    - analyses : dict[UUID, AnalysisResult]\n    --\n    + apply_analysis(uids: list[str], analysis_type: str, params: dict): list[str]\n    + get_analysis_result(uid: str): AnalysisResult\n}\n\nclass AnalysisResult {\n    - uuid : UUID\n    - name : str\n    - params : dict\n    - data : object\n    - depends_on : UUID\n    --\n}\n\nclass PCDViewerWidget {\n    - visible : bool\n    --\n    + render_data_node(points: np.ndarray, colors: np.ndarray): None\n    + clear(): None\n}\n\n&#39; Relationships\nDataManager --&gt; DataNodes : manages\nDataManager --&gt; TreeStructureWidget : updates\nDataManager --&gt; PCDViewerWidget : controls\nDataManager --&gt; AnalysisManager : applies\nDataNodes --&gt; DataNode : contains\nTreeStructureWidget --&gt; Branch : maps to\nDataNode --&gt; AnalysisResult : produces\nAnalysisResult --&gt; DataNode : relates to\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="VsBj7MzGJR5kxG5B942g-134">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;fontSize=20;fontFamily=Tahoma;" parent="1" vertex="1">
            <mxGeometry x="-461.05" y="6110" width="1958" height="865" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nactor User\ncontrol TreeStructureWidget\ncontrol DataManager #orange\nentity DataNodes\nentity PCDViewerWidget\nentity AnalysisManager\n\n== Adding a Branch ==\nUser -&gt; DataManager: Add branch (Load point cloud)\nDataManager -&gt; DataNodes: Add data node (type: raw)\nDataManager -&gt; TreeStructureWidget: Add branch to tree\nDataManager -&gt; PCDViewerWidget: Render data node\n\n== Selecting Branches ==\nUser -&gt; TreeStructureWidget: Select branches\nTreeStructureWidget -&gt; DataManager: Notify selected branches\n\n== Deleting Selected Branches ==\nUser -&gt; DataManager: Delete selected branches\nDataManager -&gt; DataNodes: Validate dependencies\nalt Dependencies Exist\n    DataManager -&gt; TreeStructureWidget: Raise error (Branch has dependent data)\nelse No Dependencies\n    DataManager -&gt; TreeStructureWidget: Remove branches from tree\n    DataManager -&gt; DataNodes: Remove data nodes from dictionary\n    DataManager -&gt; PCDViewerWidget: Update rendering\nend\n\n== Moving Selected Branches ==\nUser -&gt; TreeStructureWidget: Move selected branches\nTreeStructureWidget -&gt; TreeStructureWidget: Update parent of branch\nTreeStructureWidget -&gt; DataManager: Notify updated branch hierarchy\nDataManager -&gt; DataNodes: Validate parent dependency\nalt Dependencies Exist\n    DataManager -&gt; TreeStructureWidget: Raise error (Invalid move)\nelse No Dependencies\n    DataManager -&gt; DataNodes: Update parent-child relationship\n    DataManager -&gt; PCDViewerWidget: Update rendering if necessary\nend\n\n== Toggling Visibility ==\nUser -&gt; TreeStructureWidget: Toggle visibility of a branch\nTreeStructureWidget -&gt; DataManager: Notify visibility changes\nDataManager -&gt; PCDViewerWidget: Update visibility rendering\n\n== Applying a Task ==\nUser -&gt; DataManager: Apply a task/analysis on selected branches\nDataManager -&gt; AnalysisManager: Perform analysis\nAnalysisManager -&gt; DataManager: Return analysis result\nDataManager -&gt; DataNodes: Add derived data node (type: derived, depends_on: parent UUID)\nDataManager -&gt; TreeStructureWidget: Add new branch for derived data\nDataManager -&gt; PCDViewerWidget: Render derived data\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="FdGPhG3aANbtVTZCnWhw-2">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;fontSize=20;fontFamily=Tahoma;" parent="1" vertex="1">
            <mxGeometry x="-132.55" y="4740" width="1268" height="1312" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n\npackage \&quot;ERD for Data Management\&quot; {\n\n    entity DataManager {\n        * data_nodes : DataNodes\n        * analysis_manager : AnalysisManager\n        * tree_structure_widget : TreeStructureWidget\n        * viewer_widget : PCDViewerWidget\n    }\n\n    entity DataNodes {\n        * data_nodes : dict[UUID, DataNode]\n    }\n\n    entity AnalysisManager {\n        * analyses : dict[UUID, AnalysisResult]\n    }\n\n    entity DataNode {\n        * uuid : UUID\n        * name : str\n        * data : object\n        * parent_uid : UUID\n        * depends_on : list[UUID]\n        * tags : list[str]\n    }\n\n    entity TreeStructureWidget {\n        * branches_dict : dict[UUID, Branch]\n        * visibility_status : dict[UUID, bool]\n    }\n\n    entity Branch {\n        * uuid : UUID\n        * name : str\n        * parent_uid : UUID\n    }\n\n    entity AnalysisResult {\n        * uuid : UUID\n        * name : str\n        * params : dict\n        * data : object\n        * depends_on : list[UUID]\n    }\n\n    entity PCDViewerWidget {\n        * visible : bool\n    }\n\n    &#39; Updated Relationships\n    DataManager ||--|| DataNodes : manages\n    DataManager ||--|| TreeStructureWidget : updates\n    DataManager ||--|| PCDViewerWidget : controls\n    DataManager ||--|| AnalysisManager : applies\n\n    DataNodes ||--|{ DataNode : contains\n    TreeStructureWidget ||--|{ Branch : maps_to\n    AnalysisManager ||--|{ AnalysisResult : produces\n    AnalysisResult ||--|{ DataNode : generates\n    DataNode }|--|{ AnalysisResult : depends_on\n\n    &#39; Cardinality Legend\n    note right of DataManager : Cardinality Legend:\\n\\n||--|| : One-to-One\\n||--|{ : One-to-Many\\n}|--|{ : Many-to-Many\n\n}\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="FdGPhG3aANbtVTZCnWhw-3">
          <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;fontSize=20;fontFamily=Tahoma;" parent="1" vertex="1">
            <mxGeometry x="104.94999999999999" y="7210" width="826" height="782" as="geometry" />
          </mxCell>
        </UserObject>
