        <mxCell id="TSCh-ubsTvimD4tnIFDC-233" value="Results Processing and Visualization" style="fillColor=#ffff88;strokeColor=#9E916F;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Times New Roman;fontSize=18;" parent="1" vertex="1">
