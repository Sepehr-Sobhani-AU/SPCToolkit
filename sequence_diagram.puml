@startuml SPCToolkit_Sequence_Diagram
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 10
skinparam sequenceMessageAlign center

title SPCToolkit - Key Interaction Sequences

' ============================================================================
' SEQUENCE 1: Application Startup and Plugin Loading
' ============================================================================

== Application Startup & Plugin Discovery ==

actor User
participant "MainWindow" as MW
participant "PluginManager" as PM
participant "plugins/analysis/" as ADIR
participant "plugins/menus/" as MDIR
participant "AnalysisManager" as AM
participant "MenuPlugin" as MP

User -> MW : Start Application
activate MW

MW -> PM : Initialize
activate PM

PM -> ADIR : Scan directory
activate ADIR
ADIR --> PM : Return plugin modules
deactivate ADIR

PM -> PM : Import modules\nFind AnalysisPlugin classes
PM -> AM : Register analysis plugins
activate AM
AM -> AM : Store plugin instances
deactivate AM

PM -> MDIR : Scan directory
activate MDIR
MDIR --> PM : Return plugin modules
deactivate MDIR

PM -> PM : Import modules\nFind MenuPlugin classes
PM --> MW : Return menu plugins
deactivate PM

MW -> MP : get_menu_location()
activate MP
MP --> MW : "Action/Points"
deactivate MP

MW -> MP : get_menu_items()
activate MP
MP --> MW : [{name, action, tooltip}]
deactivate MP

MW -> MW : Build dynamic menus
MW --> User : Application ready
deactivate MW

' ============================================================================
' SEQUENCE 2: Loading Point Cloud File
' ============================================================================

== Loading Point Cloud File ==

User -> MW : File > Open Point Cloud
activate MW

MW -> MW : Show file dialog
User -> MW : Select file path

MW -> MW : global_file_manager
participant "FileManager" as FM
participant "DataNodes" as DNS
participant "DataNode" as DN
participant "TreeStructureWidget" as TSW
participant "PCDViewerWidget" as PVW

MW -> FM : load_point_cloud(file_path)
activate FM

FM -> FM : Read file using Open3D
FM -> FM : Create PointCloud object

FM -> DN : Create root DataNode
activate DN
DN -> DN : uid = UUID()\ndata = PointCloud\ndata_type = "PointCloud"\nparent_uid = None
deactivate DN

FM -> DNS : add_node(data_node)
activate DNS
DNS -> DNS : Store in collection
deactivate DNS

FM --> MW : root_node_uid
deactivate FM

MW -> TSW : add_root_node(uid)
activate TSW
TSW -> TSW : Create tree item
TSW -> DNS : get_node(uid)
activate DNS
DNS --> TSW : data_node
deactivate DNS
TSW -> TSW : Display in tree
deactivate TSW

MW -> PVW : update_visible_clouds()
activate PVW
PVW -> DNS : get_visible_nodes()
activate DNS
DNS --> PVW : [data_nodes]
deactivate DNS
PVW -> PVW : Render point cloud\nwith OpenGL VBOs
PVW --> User : Display visualization
deactivate PVW

deactivate MW

' ============================================================================
' SEQUENCE 3: Executing Analysis Plugin
' ============================================================================

== Applying Analysis Plugin (DBSCAN Clustering) ==

User -> TSW : Select node in tree
activate TSW
TSW -> TSW : Store selected_uid
deactivate TSW

User -> MW : Action > Points > Cluster Points (DBSCAN)
activate MW

MW -> MW : Identify menu action
participant "DialogBoxesManager" as DBM
participant "DBSCANPlugin" as DBSCAN

MW -> DBM : open_dialog_box("cluster_points")
activate DBM

DBM -> AM : get_plugin("dbscan_clustering")
activate AM
AM --> DBM : plugin instance
deactivate AM

DBM -> DBSCAN : get_parameters()
activate DBSCAN
DBSCAN --> DBM : {eps: {type, default, min, max, label},\nmin_samples: {...}}
deactivate DBSCAN

DBM -> DBM : Create dynamic dialog\nwith parameter inputs
DBM --> User : Show dialog
User -> DBM : Input parameters\n(eps=0.5, min_samples=10)
DBM -> DBM : Validate inputs
DBM -> DBM : emit parameters_ready signal
deactivate DBM

participant "DataManager" as DM

MW -> DM : apply_analysis("dbscan_clustering", params)
activate DM

DM -> TSW : get_selected_uid()
activate TSW
TSW --> DM : selected_uid
deactivate TSW

DM -> DNS : get_node(selected_uid)
activate DNS
DNS --> DM : parent_data_node
deactivate DNS

DM -> AM : execute_plugin("dbscan_clustering", node, params)
activate AM

AM -> DBSCAN : execute(data_node, params)
activate DBSCAN

DBSCAN -> DBSCAN : point_cloud = data_node.data
DBSCAN -> DBSCAN : Check if use_batch_processing
alt Large point cloud (use batching)
    participant "BatchProcessor" as BP
    DBSCAN -> BP : process_in_batches(point_cloud, dbscan_fn)
    activate BP
    BP -> BP : Spatial partitioning\nwith overlap
    BP -> BP : Apply DBSCAN per batch
    BP -> BP : Merge results
    BP --> DBSCAN : combined_labels
    deactivate BP
else Small point cloud
    DBSCAN -> DBSCAN : point_cloud.dbscan(eps, min_samples)
end

DBSCAN -> DBSCAN : Create Clusters object\nclusters = Clusters(labels)
DBSCAN --> AM : (clusters, "Clusters", [parent_uid])
deactivate DBSCAN

AM -> DN : Create new DataNode
activate DN
DN -> DN : uid = UUID()\ndata = clusters\ndata_type = "Clusters"\nparent_uid = parent_uid\ndepends_on = [parent_uid]
deactivate DN

AM -> DNS : add_node(cluster_node)
activate DNS
DNS -> DNS : Store node
deactivate DNS

AM --> DM : cluster_node_uid
deactivate AM

DM -> TSW : add_child_node(parent_uid, cluster_uid)
activate TSW
TSW -> TSW : Create child tree item
TSW -> TSW : Update tree display
deactivate TSW

DM --> MW : Success
deactivate DM

MW --> User : Analysis complete
deactivate MW

' ============================================================================
' SEQUENCE 4: Branch Reconstruction for Visualization
' ============================================================================

== Visualizing Derived Data (Branch Reconstruction) ==

User -> TSW : Click on Masks node
activate TSW
TSW -> DM : selection_changed(masks_uid)
activate DM

DM -> DNS : get_node(masks_uid)
activate DNS
DNS --> DM : masks_node
deactivate DNS

DM -> DM : Check if data_type\n== "PointCloud"
note right: If not PointCloud,\nneed reconstruction

DM -> DM : reconstruct_branch(masks_uid)

participant "NodeReconstructionManager" as NRM
participant "ApplyClusters" as TAC
participant "ApplyMasks" as TAM

DM -> NRM : reconstruct(masks_uid)
activate NRM

NRM -> DNS : get_node(masks_uid)
activate DNS
DNS --> NRM : masks_node
deactivate DNS

NRM -> NRM : Traverse to root
note right
    Build path:
    [root_pointcloud_uid,
     clusters_uid,
     masks_uid]
end note

NRM -> DNS : get_node(root_uid)
activate DNS
DNS --> NRM : root_node (PointCloud)
deactivate DNS

NRM -> NRM : current_pc = root_node.data.copy()

loop For each node in path (excluding root)
    NRM -> DNS : get_node(next_uid)
    activate DNS
    DNS --> NRM : next_node
    deactivate DNS

    alt data_type == "Clusters"
        NRM -> TAC : apply(current_pc, clusters_data)
        activate TAC
        TAC -> TAC : Filter/color points\nby cluster labels
        TAC --> NRM : filtered_pc
        deactivate TAC
        NRM -> NRM : current_pc = filtered_pc

    else data_type == "Masks"
        NRM -> TAM : apply(current_pc, masks_data)
        activate TAM
        TAM -> TAM : Filter points\nby boolean mask
        TAM --> NRM : filtered_pc
        deactivate TAM
        NRM -> NRM : current_pc = filtered_pc

    else data_type == "Values"
        NRM -> NRM : Apply values to attributes
    end
end

NRM --> DM : reconstructed_pointcloud
deactivate NRM

DM -> PVW : update_point_cloud(masks_uid, reconstructed_pc)
activate PVW

PVW -> PVW : Clear old VBOs
PVW -> PVW : Create new VBOs\nwith reconstructed data
PVW -> PVW : Upload to GPU
PVW -> PVW : Trigger repaint()
PVW --> User : Display filtered\npoint cloud
deactivate PVW

deactivate DM
deactivate TSW

' ============================================================================
' SEQUENCE 5: Interactive Visualization
' ============================================================================

== Interactive Visualization (Point Picking) ==

User -> PVW : Shift + Left Click
activate PVW

PVW -> PVW : mousePressEvent(event)
PVW -> PVW : Convert screen coords\nto 3D ray
PVW -> PVW : Ray-cast to find\nclosest point

alt Point found within threshold
    PVW -> PVW : Add to selected_points
    PVW -> PVW : Update selection VBO
    PVW -> PVW : repaint()
    PVW --> User : Highlight selected point
else No point found
    PVW --> User : No selection
end

deactivate PVW

User -> PVW : Mouse Wheel Scroll
activate PVW
PVW -> PVW : wheelEvent(event)
PVW -> PVW : Adjust camera zoom
PVW -> PVW : repaint()
PVW --> User : Zoomed view
deactivate PVW

User -> PVW : Left Click + Drag
activate PVW
PVW -> PVW : mouseMoveEvent(event)
PVW -> PVW : Calculate rotation delta
PVW -> PVW : Update rotation matrix
PVW -> PVW : repaint()
PVW --> User : Rotated view
deactivate PVW

' ============================================================================
' SEQUENCE 6: Saving Branch
' ============================================================================

== Saving Branch to File ==

User -> MW : Action > Save Branch
activate MW

MW -> TSW : get_selected_uid()
activate TSW
TSW --> MW : selected_uid
deactivate TSW

MW -> DM : reconstruct_and_save(selected_uid)
activate DM

DM -> NRM : reconstruct(selected_uid)
activate NRM
NRM -> NRM : [Same reconstruction\nprocess as before]
NRM --> DM : reconstructed_pc
deactivate NRM

DM -> FM : save_point_cloud(reconstructed_pc, file_path)
activate FM
FM -> FM : Convert to Open3D format
FM -> FM : Write to file (.ply/.pcd)
FM --> DM : Success
deactivate FM

DM --> MW : Saved successfully
deactivate DM

MW --> User : File saved notification
deactivate MW

@enduml
