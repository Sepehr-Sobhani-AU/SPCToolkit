G@startuml SPCToolkit_Conceptual_Diagram
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontSize 11
skinparam packageStyle rectangle

title SPCToolkit - Conceptual Architecture Diagram

' Define color scheme
skinparam component {
    BackgroundColor<<GUI>> #E3F2FD
    BackgroundColor<<Manager>> #FFF3E0
    BackgroundColor<<Data>> #E8F5E9
    BackgroundColor<<Plugin>> #F3E5F5
    BackgroundColor<<Task>> #FFF9C4
    BackgroundColor<<Service>> #FCE4EC
}

package "GUI Layer" <<GUI>> {
    [MainWindow] as MW
    [TreeStructureWidget] as TSW
    [PCDViewerWidget] as PVW
    [DialogBoxesManager] as DBM

    MW -down-> TSW : contains
    MW -down-> PVW : contains
    MW -down-> DBM : uses
    TSW <-right-> PVW : signals/updates
}

package "Data Management Layer" <<Manager>> {
    [DataManager] as DM
    [FileManager] as FM
    [AnalysisManager] as AM
    [NodeReconstructionManager] as NRM

    DM -down-> FM : uses
    DM -down-> AM : uses
    DM -down-> NRM : uses
}

package "Core Data Structures" <<Data>> {
    [DataNodes\nCollection] as DNS
    [DataNode\nuid, data, parent_uid\ndepends_on, tags] as DN

    package "Data Types" {
        [PointCloud\npoints, colors, normals\nattributes, methods] as PC
        [Clusters\nlabels, colors] as CL
        [Masks\nboolean array] as MA
        [Values\nper-point data] as VA
    }

    DNS --> DN : manages
    DN --> PC : contains
    DN --> CL : contains
    DN --> MA : contains
    DN --> VA : contains
}

package "Reconstruction Tasks" <<Task>> {
    [ApplyMasks] as TM
    [ApplyClusters] as TC
    [ApplyValues] as TV
    [ApplyFilters] as TF

    note right of TM
        Convert derived data types
        back to PointCloud for
        visualization
    end note
}

package "Plugin System" <<Plugin>> {
    [PluginManager] as PM

    package "Analysis Plugins" {
        [DBSCANPlugin] as AP1
        [FilterPlugin] as AP2
        [EigenvaluePlugin] as AP3
        [DrapeOnXYPlanePlugin] as AP4

        interface "AnalysisPlugin" as IAP
        IAP <|.. AP1
        IAP <|.. AP2
        IAP <|.. AP3
        IAP <|.. AP4
    }

    package "Menu Plugins" {
        [SaveBranchMenuPlugin] as MP1
        [PointsMenuPlugin] as MP2

        interface "MenuPlugin" as IMP
        IMP <|.. MP1
        IMP <|.. MP2
    }

    PM --> IAP : discovers
    PM --> IMP : discovers
}

package "Support Services" <<Service>> {
    [BatchProcessor] as BP
    [GlobalVariables\nSingleton Access] as GV
}

' Main connections
MW --> DM : coordinates
MW --> PM : loads plugins

TSW --> DM : selection events
PVW --> DM : requests data

DBM --> AM : parameter input

DM --> DNS : manages
AM --> DNS : creates nodes
FM --> DNS : creates root nodes

NRM --> TM : uses
NRM --> TC : uses
NRM --> TV : uses
NRM --> TF : uses

AM --> IAP : executes
MW --> IMP : builds menus

BP --> PC : processes large clouds

GV .down.> FM : provides access
GV .down.> DM : provides access
GV .down.> TSW : provides access
GV .down.> PVW : provides access
GV .down.> DNS : provides access

' Data flow annotations
note top of MW
    Entry point
    Dynamically builds UI from plugins
end note

note bottom of DM
    Central coordinator
    Orchestrates data flow
end note

note right of DNS
    Tree-based hierarchical
    data management
    Each node tracks dependencies
end note

note left of NRM
    Traverses dependency tree
    Applies sequential transformations
    Converts derived types to PointCloud
end note

' Workflow example
note as workflow
    **Typical Workflow:**
    1. User loads point cloud → FileManager creates root PointCloud DataNode
    2. User applies DBSCAN → AnalysisManager executes plugin → Creates Clusters DataNode
    3. User filters clusters → Creates Masks DataNode (depends on Clusters)
    4. User visualizes Masks → DataManager reconstructs branch:
       • Traverse: Masks ← Clusters ← PointCloud
       • Apply: ApplyClusters task → ApplyMasks task
       • Result: Filtered PointCloud sent to PCDViewerWidget
end note

workflow .up. DM

@enduml
